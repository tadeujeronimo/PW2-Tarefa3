@model Projeto1_IF.Models.TbPaciente

@{
    ViewData["Title"] = "Detalhes do paciente";
}

<h1>Detalhes do paciente</h1>

<div>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            Nome
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Nome)
        </dd>
    </dl>
        <dt class = "col-sm-2">
            RG
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Rg)
        </dd>
    </dl>
        <dt class = "col-sm-2">
            CPF
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Cpf)
        </dd>
    </dl>
        <dt class = "col-sm-2">
            Data de nascimento
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.DataNascimento)
        </dd>
    </dl>
        <dt class = "col-sm-2">
            Nome do responsável
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.NomeResponsavel)
        </dd>
    </dl>
        <dt class = "col-sm-2">
            Sexo
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Sexo)
        </dd>
    </dl>
        <dt class = "col-sm-2">
            Etnia
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Etnia)
        </dd>
    </dl>
        <dt class = "col-sm-2">
            Endereço
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Endereco)
        </dd>
    </dl>
        <dt class = "col-sm-2">
            Bairro
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Bairro)
        </dd>
    </dl>
        <dt class = "col-sm-2">
            Cidade
        </dt>
        <dd class = "col-sm-10">
            @Model?.IdCidadeNavigation?.Nome
        </dd>
    </dl>
        <dt class = "col-sm-2">
            Telefone residencial
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.TelResidencial)
        </dd>
    </dl>
        <dt class = "col-sm-2">
            Telefone comercial
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.TelComercial)
        </dd>
    </dl>
        <dt class = "col-sm-2">
            Celular
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.TelCelular)
        </dd>
    </dl>
        <dt class = "col-sm-2">
            Profissão
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Profissao)
        </dd>
    </dl>
        <dt class = "col-sm-2">
            É atleta?
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.FlgAtleta)
        </dd>
    </dl>
        <dt class = "col-sm-2">
            É gestante?
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.FlgGestante)
        </dd>
    </dl>
</div>
<div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-idpaciente="@Model?.IdPaciente" class="btn btn-primary">Editar</a>
        <a asp-action="Index" class="btn btn-secondary">Voltar</a>
    </div>
</div>
