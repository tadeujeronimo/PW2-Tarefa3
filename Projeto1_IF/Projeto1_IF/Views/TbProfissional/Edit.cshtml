@model Projeto1_IF.Models.TbProfissional

@{
    ViewData["Title"] = "Editar profissional";
    bool podeEditarCpf = (bool?)ViewData["PodeEditarCpf"] ?? false;
}

<h1>Editar profissional</h1>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="IdProfissional" />

            <div class="form-group">
                <label asp-for="Nome" class="control-label"></label>
                <input asp-for="Nome" class="form-control" />
                <span asp-validation-for="Nome" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Cpf" class="control-label"></label>
                @if (podeEditarCpf)
                {
                    <input asp-for="Cpf" class="form-control" />
                }
                else
                {
                    <input asp-for="Cpf" class="form-control" readonly disabled />
                    <small class="form-text text-muted">O CPF não pode ser alterado pelo próprio profissional.</small>
                }
                <span asp-validation-for="Cpf" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="CrmCrn" class="control-label">CRM/CRN</label>
                <input asp-for="CrmCrn" class="form-control" />
            </div>

            <div class="form-group">
                <label asp-for="Especialidade" class="control-label"></label>
                <input asp-for="Especialidade" class="form-control" />
            </div>

            <div class="form-group">
                <label asp-for="Logradouro" class="control-label"></label>
                <input asp-for="Logradouro" class="form-control" />
            </div>

            <div class="form-group">
                <label asp-for="Numero" class="control-label"></label>
                <input asp-for="Numero" class="form-control" />
                <span asp-validation-for="Numero" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Bairro" class="control-label"></label>
                <input asp-for="Bairro" class="form-control" />
                <span asp-validation-for="Bairro" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Cep" class="control-label"></label>
                <input asp-for="Cep" class="form-control" />
                <span asp-validation-for="Cep" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="IdCidade" class="control-label">Cidade</label>
                <select asp-for="IdCidade" class="form-control" asp-items="ViewBag.IdCidade">
                    <option value="">-- Selecione a cidade --</option>
                </select>
                <span asp-validation-for="IdCidade" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Ddd1" class="control-label"></label>
                <input asp-for="Ddd1" class="form-control" />
            </div>
            <div class="form-group">
                <label asp-for="Telefone1" class="control-label"></label>
                <input asp-for="Telefone1" class="form-control" />
            </div>
            <div class="form-group">
                <label asp-for="Ddd2" class="control-label"></label>
                <input asp-for="Ddd2" class="form-control" />
            </div>
            <div class="form-group">
                <label asp-for="Telefone2" class="control-label"></label>
                <input asp-for="Telefone2" class="form-control" />
            </div>

            <div class="form-group">
                <label asp-for="Salario" class="control-label"></label>
                <input asp-for="Salario" class="form-control" />
            </div>

            @if (podeEditarCpf)
            {
                <div class="form-group">
                    <label asp-for="IdTipoAcesso" class="control-label">Tipo de acesso</label>
                    <select asp-for="IdTipoAcesso" class="form-control" asp-items="ViewBag.IdTipoAcesso">
                        <option value="">-- Selecione --</option>
                    </select>
                </div>
            }

            <div class="form-group mt-3">
                <input type="submit" value="Salvar" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Details" asp-route-idprofissional="@Model.IdProfissional">Voltar</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
