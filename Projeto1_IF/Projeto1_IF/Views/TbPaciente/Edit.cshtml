@model Projeto1_IF.Models.TbPaciente

@{
    ViewData["Title"] = "Editar paciente";
}

<h1>Editar paciente</h1>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit" asp-route-idpaciente="@Model.IdPaciente">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="IdPaciente" />
            <div class="form-group">
                <label asp-for="Nome" class="control-label">Nome *</label>
                <input asp-for="Nome" class="form-control" />
                <span asp-validation-for="Nome" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Rg" class="control-label">RG *</label>
                <input asp-for="Rg" class="form-control" />
                <span asp-validation-for="Rg" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Cpf" class="control-label">CPF *</label>
                <input asp-for="Cpf" class="form-control" />
                <span asp-validation-for="Cpf" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="DataNascimento" class="control-label">Data de nascimento *</label>
                <input asp-for="DataNascimento" class="form-control" />
                <span asp-validation-for="DataNascimento" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="NomeResponsavel" class="control-label">Nome do responsável</label>
                <input asp-for="NomeResponsavel" class="form-control" />
                <span asp-validation-for="NomeResponsavel" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Sexo" class="control-label">Sexo *</label>
                <input asp-for="Sexo" class="form-control" />
                <span asp-validation-for="Sexo" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Etnia" class="control-label">Etnia</label>
                <input asp-for="Etnia" class="form-control" />
                <span asp-validation-for="Etnia" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Endereco" class="control-label">Endereço</label>
                <input asp-for="Endereco" class="form-control" />
                <span asp-validation-for="Endereco" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Bairro" class="control-label">Bairro</label>
                <input asp-for="Bairro" class="form-control" />
                <span asp-validation-for="Bairro" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="IdCidade" class="control-label">Cidade</label>
                <select asp-for="IdCidade" class="form-control" asp-items="ViewBag.IdCidade">
                    <option value="">-- Selecione a cidade --</option>
                </select>
                <span asp-validation-for="IdCidade" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="TelResidencial" class="control-label">Telefone residencial</label>
                <input asp-for="TelResidencial" class="form-control" />
                <span asp-validation-for="TelResidencial" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="TelComercial" class="control-label">Telefone comercial</label>
                <input asp-for="TelComercial" class="form-control" />
                <span asp-validation-for="TelComercial" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="TelCelular" class="control-label">Celular</label>
                <input asp-for="TelCelular" class="form-control" />
                <span asp-validation-for="TelCelular" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Profissao" class="control-label">Profissão</label>
                <input asp-for="Profissao" class="form-control" />
                <span asp-validation-for="Profissao" class="text-danger"></span>
            </div>
            <div class="form-group form-check">
                <label asp-for="FlgAtleta" class="control-label">É atleta?</label>
                <input asp-for="FlgAtleta" class="form-check-input" />
                <span asp-validation-for="FlgAtleta" class="text-danger"></span>
            </div>
            <div class="form-group form-check">
                <label asp-for="FlgGestante" class="control-label">É gestante?</label>
                <input asp-for="FlgGestante" class="form-check-input" />
                <span asp-validation-for="FlgGestante" class="text-danger"></span>
            </div>
            <div class="d-flex gap-2 mt-3">
                <button type="submit" class="btn btn-primary">Salvar alterações</button>
                <a asp-action="Index" class="btn btn-secondary">Voltar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
