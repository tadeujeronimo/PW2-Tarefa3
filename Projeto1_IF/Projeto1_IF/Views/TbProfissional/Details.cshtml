@model Projeto1_IF.Models.TbProfissional

@{
    ViewData["Title"] = "Detalhes do profissional";
}

<h1>Detalhes do profissional</h1>

<div>
    <dl class="row">
        <dt class="col-sm-3">Nome</dt>
        <dd class="col-sm-9">@Model.Nome</dd>

        <dt class="col-sm-3">CPF</dt>
        <dd class="col-sm-9">@Model.Cpf</dd>

        <dt class="col-sm-3">CRM/CRN</dt>
        <dd class="col-sm-9">@Model.CrmCrn</dd>

        <dt class="col-sm-3">Especialidade</dt>
        <dd class="col-sm-9">@Model.Especialidade</dd>
    </dl>

    <hr />
    <dl class="row">
        <dt class="col-sm-3">Endereço</dt>
        <dd class="col-sm-9">@Model.Logradouro, @Model.Numero - @Model.Bairro, @Model.IdCidadeNavigation?.Nome - CEP @Model.Cep</dd>

        <dt class="col-sm-3">Telefones</dt>
        <dd class="col-sm-9">
            (@Model.Ddd1) @Model.Telefone1
            @if (!string.IsNullOrWhiteSpace(Model.Telefone2))
            {
                <text> / (@Model.Ddd2) @Model.Telefone2</text>
            }
        </dd>
    </dl>

    <hr />
    <dl class="row">
        <dt class="col-sm-3">Plano</dt>
        <dd class="col-sm-9">@Model.IdContratoNavigation?.IdPlanoNavigation?.Nome</dd>

        @if (User.IsInRole("GerenteMedico") || User.IsInRole("GerenteNutricionista") || User.IsInRole("GerenteGeral"))
        {
            <dt class="col-sm-3">Salário</dt>
            <dd class="col-sm-9">@Model.Salario?.ToString("C")</dd>
        }
    </dl>
</div>
<div>
    <a class="btn btn-primary" asp-action="Edit" asp-route-idprofissional="@Model.IdProfissional">Editar</a>
    @if (User.IsInRole("GerenteMedico") || User.IsInRole("GerenteNutricionista") || User.IsInRole("GerenteGeral"))
    {
        <a class="btn btn-secondary" asp-action="Index">Voltar para a lista</a>
    }
    else
    {
        <a class="btn btn-secondary" asp-controller="Home" asp-action="Index">Voltar</a>
    }
</div>
